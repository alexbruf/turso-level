{
  "name": "@alexbruf/turso-level",
  "version": "0.1.0",
  "description": "An abstract-level database backed by Turso / libSQL",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
