  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexbruf/turso-level.git"
  },
  "homepage": "https://github.com/alexbruf/turso-level#readme",
  "bugs": {
    "url": "https://github.com/alexbruf/turso-level/issues"
  },
  "keywords": ["abstract-level", "leveldb", "turso", "libsql", "sqlite", "serverless"]
